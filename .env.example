# ─────────────────────────────────────────────────────────────
# HireEZ — Environment Configuration
# Copy this file to .env and fill in your credentials.
# ─────────────────────────────────────────────────────────────

# ── Database (MySQL) ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hireez
DB_USER=root
DB_PASSWORD=your_mysql_password

# ── AI ───────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── Security ─────────────────────────────────────────────────
SECRET_KEY=your_secret_key_here

# ── GitHub ───────────────────────────────────────────────────
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_pat

# ── Email (SMTP) ───────────────────────────────────────────────
# For Gmail: enable 2FA, then generate an App Password
#   https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com

# ── Google OAuth (Calendar + Meet) ───────────────────────────
# Create OAuth 2.0 credentials in Google Cloud Console:
#   https://console.cloud.google.com/apis/credentials
# Enable Google Calendar API.
# Add authorized redirect URI matching GOOGLE_REDIRECT_URI.
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8002/google/oauth/callback

# ── Application ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:8501
API_BASE=http://localhost:8000
